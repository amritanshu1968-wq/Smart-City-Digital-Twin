{
  "name": "Smart City Digital Twin Theme",
  "dataColors": [
    "#2563EB",
    "#10B981",
    "#F59E0B",
    "#EF4444",
    "#8B5CF6",
    "#06B6D4",
    "#EC4899",
    "#6B7280"
  ],
  "background": "#F4F7FB",
  "foreground": "#1F2937",
  "tableAccent": "#2563EB",
  "textClasses": {
    "callout": {
      "fontSize": 24,
      "fontFace": "Segoe UI Semibold",
      "color": "#1F2937"
    },
    "title": {
      "fontSize": 12,
      "fontFace": "Segoe UI Semibold",
      "color": "#1F2937"
    },
    "header": {
      "fontSize": 10,
      "fontFace": "Segoe UI Semibold",
      "color": "#6B7280"
    },
    "label": {
      "fontSize": 9,
      "fontFace": "Segoe UI",
      "color": "#6B7280"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false,
            "color": {
              "solid": {
                "color": "#E5E7EB"
              }
            },
            "radius": 12
          }
        ],
        "shadow": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#000000"
              }
            },
            "transparency": 95,
            "preset": "BottomRight"
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "title": {
              "show": true
            }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": {
              "solid": {
                "color": "#F4F7FB"
              }
            },
            "transparency": 0
          }
        ]
      }
    }
  }
}
